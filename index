<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Заявка поставщикам</title>
    <style>
      :root {
        --bg: #f5f6f8;
        --surface: #fff;
        --text: #1f2937;
        --muted: #6b7280;
        --primary: #1d4ed8;
        --border: #e5e7eb;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
      }
      .container { max-width: 1200px; margin: 20px auto; padding: 0 16px; }
      .title { margin: 0 0 12px; }
      .tabs {
        position: sticky;
        top: 0;
        z-index: 20;
        background: var(--bg);
        padding: 10px 0;
        display: flex;
        gap: 8px;
        overflow-x: auto;
        border-bottom: 1px solid var(--border);
      }
      .tab {
        border: 1px solid var(--border);
        background: #fff;
        padding: 8px 12px;
        border-radius: 8px;
        cursor: pointer;
        white-space: nowrap;
      }
      .tab.active {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
      }
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
      }
      .supplier-meta {
        padding: 12px 14px;
        border-bottom: 1px solid var(--border);
        color: var(--muted);
        font-size: 14px;
      }
      .table-wrap { max-height: 68vh; overflow: auto; }
      table { width: 100%; border-collapse: collapse; }
      thead th {
        position: sticky;
        top: 0;
        z-index: 10;
        background: #f9fafb;
        border-bottom: 2px solid var(--border);
      }
      th, td {
        border-bottom: 1px solid var(--border);
        padding: 10px;
        text-align: left;
      }
      .qty-input {
        width: 100px;
        padding: 6px 8px;
      }
      .muted { color: var(--muted); }
      .actions {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-top: 12px;
      }
      button {
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        cursor: pointer;
      }
      button:disabled { opacity: 0.6; cursor: not-allowed; }
      .status { font-size: 14px; }
      .status.error { color: #b91c1c; }
      .status.ok { color: #166534; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1 class="title">Заявка поставщикам</h1>
      <div id="tabs" class="tabs"></div>
      <div class="card">
        <div id="supplierMeta" class="supplier-meta">Загрузка…</div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Товар</th>
                <th>Цена за 1 ед.</th>
                <th>Ед.</th>
                <th>Количество</th>
              </tr>
            </thead>
            <tbody id="rows"></tbody>
          </table>
        </div>
      </div>
      <div class="actions">
        <button id="submitBtn" disabled>Отправить заявку</button>
        <span id="status" class="status muted"></span>
      </div>
    </div>

    <script>
      let state = { suppliers: [], products: [], activeSupplier: null };

      document.addEventListener('DOMContentLoaded', init);

      function init() {
        setStatus('Загрузка данных…');
        google.script.run
          .withSuccessHandler(data => {
            state.suppliers = data.suppliers || [];
            state.products = data.products || [];

            if (!state.suppliers.length) {
              setStatus('Нет поставщиков на листе "О поставщике".', true);
              return;
            }

            state.activeSupplier = state.suppliers[0].name;
            renderTabs();
            renderActiveSupplier();
            document.getElementById('submitBtn').disabled = false;
            setStatus('Выберите товары и введите количество.');
          })
          .withFailureHandler(err => {
            setStatus(err.message || 'Ошибка загрузки данных', true);
          })
          .getData();

        document.getElementById('submitBtn').addEventListener('click', submitOrder);
      }

      function renderTabs() {
        const tabs = document.getElementById('tabs');
        tabs.innerHTML = '';

        state.suppliers.forEach(supplier => {
          const btn = document.createElement('button');
          btn.className = 'tab' + (supplier.name === state.activeSupplier ? ' active' : '');
          btn.textContent = supplier.name;
          btn.addEventListener('click', () => {
            state.activeSupplier = supplier.name;
            renderTabs();
            renderActiveSupplier();
          });
          tabs.appendChild(btn);
        });
      }

      function renderActiveSupplier() {
        const supplier = state.suppliers.find(s => s.name === state.activeSupplier);
        const rows = document.getElementById('rows');
        const meta = document.getElementById('supplierMeta');

        const supplierProducts = state.products.filter(p => p.supplier === state.activeSupplier);

        meta.textContent = supplier
          ? `Контакт: ${supplier.contact || '—'} | Мин. заказ: ${supplier.minOrder || 0} | Условия: ${supplier.terms || '—'}`
          : '';

        rows.innerHTML = '';

        if (!supplierProducts.length) {
          rows.innerHTML = '<tr><td colspan="4" class="muted">Для этого поставщика нет товаров в листе "Цены".</td></tr>';
          return;
        }

        supplierProducts.forEach(item => {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>${escapeHtml(item.name)}</td>
            <td>${formatMoney(item.price)}</td>
            <td>${escapeHtml(item.unit || 'шт')}</td>
            <td><input class="qty-input" type="number" min="0" step="0.01" data-name="${escapeHtml(item.name)}" placeholder="0" /></td>
          `;
          rows.appendChild(tr);
        });
      }

      function submitOrder() {
        const inputs = Array.from(document.querySelectorAll('#rows .qty-input'));
        const items = inputs
          .map(input => ({ name: input.dataset.name, quantity: Number(input.value || 0) }))
          .filter(item => item.quantity > 0);

        if (!items.length) {
          setStatus('Добавьте хотя бы одну позицию с количеством больше 0.', true);
          return;
        }

        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        setStatus('Отправка заявки…');

        google.script.run
          .withSuccessHandler(res => {
            setStatus(`${res.message}. Открыть таблицу: ${res.url}`, false, true);
            document.querySelectorAll('#rows .qty-input').forEach(i => i.value = '');
            btn.disabled = false;
          })
          .withFailureHandler(err => {
            setStatus(err.message || 'Ошибка сохранения заявки', true);
            btn.disabled = false;
          })
          .submitOrder({ supplier: state.activeSupplier, items });
      }

      function setStatus(message, isError = false, isSuccess = false) {
        const node = document.getElementById('status');
        node.className = 'status ' + (isError ? 'error' : isSuccess ? 'ok' : 'muted');
        node.textContent = message;
      }

      function formatMoney(value) {
        return new Intl.NumberFormat('ru-RU', { maximumFractionDigits: 2 }).format(value || 0) + ' ₽';
      }

      function escapeHtml(str) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }
    </script>
  </body>
</html>
